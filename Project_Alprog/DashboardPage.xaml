<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Project_Alprog.DashboardPage"
             Title="Pusat Kendali Utama"
             BackgroundColor="#F4F6F8">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="25">

            <Frame BackgroundColor="#2C3E50" CornerRadius="15" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Status Stasiun: AMAN" TextColor="#2ECC71" FontAttributes="Bold" FontSize="14" />
                    <Label Text="Pusat Komando Seismik" FontSize="22" FontAttributes="Bold" TextColor="White" />

                    <Label x:Name="UserRoleLabel" Text="Memuat status..." TextColor="#BDC3C7" FontSize="14" Margin="0,5,0,0"/>
                </VerticalStackLayout>
            </Frame>

            <VerticalStackLayout x:Name="AdminSection" IsVisible="True" Spacing="15">
                <Label Text="Panel Koordinator Pusat" FontAttributes="Bold" FontSize="16" TextColor="#7F8C8D" />

                <Grid ColumnDefinitions="*, *" RowDefinitions="Auto" ColumnSpacing="15">
                    <Frame Grid.Column="0" BackgroundColor="#E74C3C" CornerRadius="12" Padding="15" HasShadow="True">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="⚙️" FontSize="24" HorizontalOptions="Center" />
                            <Label Text="Kalibrasi Sensor" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="1" BackgroundColor="#C0392B" CornerRadius="12" Padding="15" HasShadow="True">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="📊" FontSize="24" HorizontalOptions="Center" />
                            <Label Text="Log Tektonik" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="#D5D8DC" Margin="0,5" />

            <VerticalStackLayout x:Name="UserSection" IsVisible="True" Spacing="15">
                <Label Text="Panel Operator Lapangan" FontAttributes="Bold" FontSize="16" TextColor="#7F8C8D" />

                <Grid ColumnDefinitions="*, *" RowDefinitions="Auto" ColumnSpacing="15">
                    <Frame Grid.Column="0" BackgroundColor="#2980B9" CornerRadius="12" Padding="15" HasShadow="True">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="📈" FontSize="24" HorizontalOptions="Center" />
                            <Label Text="Pantau Grafis" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="1" BackgroundColor="#3498DB" CornerRadius="12" Padding="15" HasShadow="True">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="📡" FontSize="24" HorizontalOptions="Center" />
                            <Label Text="Status Jaringan" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>